# VeilMap Environment Variables
# Copy to .env.local and fill in your values

DATABASE_URL=postgresql://veilmap:password@localhost:5432/veilmap
NEXTAUTH_SECRET=your-secret-here-change-me
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001
UPLOAD_DIR=/var/www/veilmap/uploads
MAX_UPLOAD_SIZE_MB=20
AUTH_SECRET=your-secret-here-change-me
